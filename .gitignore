# .gitignore
# R History and Session Data
.Rhistory
.Rapp.history

# R Session Data files
*.RData
*.rda

# User-specific files
.Ruserdata

# Environment variables (contains sensitive credentials)
.Renviron
.Renviron.local

# Credentials file (contains Nextcloud credentials)
credentials.R

# OAuth tokens (shinyapps.io deployment)
.httr-oauth
.httr-oauth2

# Shinyapps.io deployment credentials and config
rsconnect/
.rsconnect/
*.dcf

# Packrat (R package management)
packrat/lib*/
packrat/src/

# renv (R environment management)
renv/
.Rprofile

# Temporary files
*~
*.swp
*.swo
*#

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE files
.vscode/
.idea/
*.Rproj
*.Rproj.user

# Output files
*.log
*.out